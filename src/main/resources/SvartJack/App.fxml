<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.TextField?>

<AnchorPane fx:id="background" prefHeight="900.0" prefWidth="1440.0"
            xmlns="http://javafx.com/javafx/8.0.171"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="SvartJack.SvartJackController">

<!--Dealer-->
    <Pane fx:id="dealer" prefWidth="200" prefHeight="150" layoutX="620" layoutY="50">
        <children>
            <Label text="Dealer" layoutX="10" layoutY="10"/>
        </children>
    </Pane>

    
<!--Add player-->
    <VBox fx:id="addPlayerBox" spacing="10" alignment="CENTER">

        <Button fx:id="addPlayerButton1" text="Add player" onAction="#addPlayer1"/>
        <TextField fx:id="addPlayerTextField" promptText="Player name"/>
        <Button fx:id="addPlayerButton2" text="Add player" onAction="#addPlayer"/>

    </VBox>

<!--Deposit-->
    <VBox fx:id="depositBox" spacing="10" alignment="CENTER">

        <Button fx:id="depositButton1" text="Deposit" onAction="#deposit1"/>
        <TextField fx:id="depositNameTextField" promptText="Name"/>
        <TextField fx:id="depositAmountTextField" promptText="Amount"/>
        <Button fx:id="depositButton2" text="Deposit" onAction="#deposit"/>

    </VBox>

<!--Spillere-->
    <HBox fx:id="players" spacing="50" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" layoutY="600">
        <children>
            <Pane fx:id="player1">
                <children>
                    <Label fx:id="player1Label" text="" layoutX="10" layoutY="10"/>
                    <Label fx:id="player1Balance" text="" layoutX="10" layoutY="30"/>
                    <Circle fx:id="betCircle1" radius="40"/>
                </children>
            </Pane>

            <Pane fx:id="player2">
                <children>
                    <Label fx:id="player2Label" text="" layoutX="10" layoutY="10"/>
                    <Label fx:id="player2Balance" text="" layoutX="10" layoutY="30"/>
                    <Circle fx:id="betCircle2" radius="40"/>
                </children>
            </Pane>

            <Pane fx:id="player3">
                <children>
                    <Label fx:id="player3Label" text="" layoutX="10" layoutY="10"/>
                    <Label fx:id="player3Balance" text="" layoutX="10" layoutY="30"/>
                    <Circle fx:id="betCircle3" radius="40"/>
                </children>
            </Pane>

            <Pane fx:id="player4">
                <children>
                    <Label fx:id="player4Label" text="" layoutX="10" layoutY="10"/>
                    <Label fx:id="player4Balance" text="" layoutX="10" layoutY="30"/>
                    <Circle fx:id="betCircle4" radius="40"/>
                </children>
            </Pane>

            <Pane fx:id="player5">
                <children>
                    <Label fx:id="player5Label" text="" layoutX="10" layoutY="10"/>
                    <Label fx:id="player5Balance" text="" layoutX="10" layoutY="30"/>
                    <Circle fx:id="betCircle5" radius="40"/>
                </children>
            </Pane>
        </children>
    </HBox>

    <!-- Knapper -->
    <Button fx:id="hitButton" text="Hit" layoutX="50" layoutY="300" prefWidth="80" prefHeight="40"/>
    <Button fx:id="standButton" text="Stand" layoutX="50" layoutY="360" prefWidth="80" prefHeight="40"/>
    <Button fx:id="splitButton" text="Split" layoutX="50" layoutY="420" prefWidth="80" prefHeight="40"/>

</AnchorPane>